prometheus.scrape "app" {
	targets         = [{__address__ = "host.docker.internal:8080", instance = "local"}]
	metrics_path    = "/actuator/prometheus"
	scrape_interval = "15s"
	forward_to      = [prometheus.relabel.app_filter.receiver]
}

prometheus.relabel "app_filter" {
	forward_to = [prometheus.remote_write.central.receiver]

	rule {
		source_labels = ["__name__", "uri"]
		regex         = "http_server_requests_seconds.*;(/actuator/.*|/swagger-ui.*|/v3/api-docs.*)"
		action        = "drop"
	}
}

prometheus.scrape "rabbitmq" {
	targets         = [{__address__ = "host.docker.internal:15692", application = "rabbitmq"}]
	scrape_interval = "15s"
	forward_to      = [prometheus.remote_write.central.receiver]
}

prometheus.exporter.unix "host" {
	procfs_path = "/host/proc"
	sysfs_path  = "/host/sys"
	rootfs_path = "/rootfs"
}

prometheus.scrape "host" {
	targets         = prometheus.exporter.unix.host.targets
	scrape_interval = "15s"
	forward_to      = [prometheus.remote_write.central.receiver]
}

prometheus.remote_write "central" {
	external_labels = {env = "local"}

	endpoint {
		url = "http://host.docker.internal:9090/api/v1/write"
	}
}

discovery.docker "containers" {
	host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
	targets = discovery.docker.containers.targets

	rule {
		source_labels = ["__meta_docker_container_name"]
		regex         = "/(.*)"
		target_label  = "container"
	}

	rule {
		source_labels = ["__meta_docker_container_label_ditda_logs_app"]
		regex         = "(.+)"
		target_label  = "app"
	}

	rule {
		source_labels = ["__meta_docker_container_label_ditda_logs_service"]
		regex         = "(.+)"
		target_label  = "service"
	}
}

loki.source.docker "default" {
	host       = "unix:///var/run/docker.sock"
	targets    = discovery.relabel.containers.output
	forward_to = [loki.write.central.receiver]
}

loki.write "central" {
	external_labels = {env = "local"}

	endpoint {
		url = "http://host.docker.internal:3100/loki/api/v1/push"
	}
}

otelcol.receiver.otlp "default" {
	http {
		endpoint = "0.0.0.0:4318"
	}

	output {
		traces = [otelcol.processor.batch.default.input]
	}
}

otelcol.processor.batch "default" {
	output {
		traces = [otelcol.exporter.otlphttp.tempo.input]
	}
}

otelcol.exporter.otlphttp "tempo" {
	client {
		endpoint = "http://host.docker.internal:4319"
	}
}
